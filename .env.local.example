# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — use it for local database and secrets.

# Database (local: SQLite file path; production: e.g. PostgreSQL URL)
# SQLite: data is stored in a file (e.g. prisma/dev.db) on your machine
DATABASE_URL="file:./dev.db"

# Auth: secret to sign session cookies (min 16 characters). Generate with: openssl rand -base64 24
AUTH_SECRET="change-me-to-a-long-random-string-at-least-16-chars"

# First time after pulling User model: npx prisma migrate dev --name add_user && npx prisma db seed
# (Creates User table and default user admin/admin; edit users only via database.)

# For PostgreSQL later, use:
# DATABASE_URL="postgresql://user:password@localhost:5432/swl_invoice"
